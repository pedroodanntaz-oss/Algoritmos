algoritmo "Streaming"
var
   telas : inteiro
inicio
   escreva("Quantas telas simultâneas: ")
   leia(telas)

   se (telas = 1) entao
      escreva("Plano Mobile")
   senao se (telas = 2) entao
      escreva("Plano Padrão")
   senao se (telas = 4) entao
      escreva("Plano Premium")
   senao
      escreva("Opção Inválida")
   fimse
fimalgoritmo
